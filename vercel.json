{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/fetch-news",
      "schedule": "30 11 * * 1-5"
    },
    {
      "path": "/api/briefing",
      "schedule": "0 12 * * 1-5"
    },
    {
      "path": "/api/send-briefing-email",
      "schedule": "15 12 * * 1-5"
    }
  ]
}
